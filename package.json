{
  "name": "peerprep-g03",
  "private": true,
  "workspaces": [
    "packages/*",
    "questionService",
    "userService",
    "client"
  ],
  "scripts": {
    "client:dev": "npm --prefix client start",
    "question:dev": "npm --prefix questionService/server run dev",
    "matching:dev": "npm --prefix matchingService/server run dev",
    "collaboration:dev": "npm --prefix collaborationService/server run dev",
    "user:dev": "npm --prefix userService/server run dev",
    "client:start": "npm --prefix client start",
    "question:start": "npm --prefix questionService/server start",
    "matching:start": "npm --prefix matchingService/server start",
    "collaboration:start": "npm --prefix collaborationService/server start",
    "user:start": "npm --prefix userService/server start",
    "dev": "concurrently \"npm run client:dev\" \"npm run question:dev\" \"npm run user:dev\" \"npm run matching:dev\" \"npm run collaboration:dev\"",
    "start": "concurrently \"npm run question:start\" \"npm run user:start\" \"npm run matching:start\" \"npm run collaboration:start\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "@peerprep/auth": "workspace:*",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "mongoose": "^8.23.0",
    "nodemon": "^3.1.14"
  }
}
